# =============================================================================
# HackForge environment configuration
# Copy to .env and adjust for your environment:
#   cp .env.example .env
#
# Local dev (npm run dev): use localhost values below.
# Debian production (Docker): set your server domain/IP and host paths.
# =============================================================================

# -----------------------------------------------------------------------------
# Public URL (baked into the Next.js client at image build time)
# Local:   http://localhost:3000
# Server:  https://labs.example.com  or  http://203.0.113.10:3004
# Rebuild after changing: docker compose build --no-cache hackforge
# -----------------------------------------------------------------------------
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# -----------------------------------------------------------------------------
# Host port published on the machine running Docker Compose
# Local Docker Desktop: 3004 (or any free port)
# Debian server:        80 if fronted by nginx, or 3004 for direct access
# -----------------------------------------------------------------------------
HOST_PORT=3004

# Image tag for deploy/rollback tracking
APP_VERSION=latest

# -----------------------------------------------------------------------------
# Persistent application data (SQLite, uploads, server-side state)
# Inside the container — do not change unless you also update the volume mount.
# -----------------------------------------------------------------------------
DATA_DIR=/app/data
DATABASE_PATH=/app/data/hackforge.db

# -----------------------------------------------------------------------------
# Host paths (Debian production examples)
# LAB_DOCKER_DIR=/opt/hackforge/docker
# DOCKER_SOCKET=/var/run/docker.sock
# -----------------------------------------------------------------------------
LAB_DOCKER_DIR=./docker
DOCKER_SOCKET=/var/run/docker.sock

# -----------------------------------------------------------------------------
# Optional PostgreSQL (enable with: docker compose --profile postgres up -d)
# When using postgres, set DATABASE_URL and start with the postgres profile.
# -----------------------------------------------------------------------------
# POSTGRES_USER=hackforge
# POSTGRES_PASSWORD=change-me-to-a-long-random-secret
# POSTGRES_DB=hackforge
# DATABASE_URL=postgresql://hackforge:change-me-to-a-long-random-secret@postgres:5432/hackforge
